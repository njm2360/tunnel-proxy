FROM nginx:alpine
RUN apk add --no-cache openssl && \
    openssl req -x509 -newkey rsa:2048 -nodes \
      -keyout /etc/nginx/ssl.key \
      -out /etc/nginx/ssl.crt \
      -days 3650 -subj '/CN=httpbin-tls' 2>/dev/null && \
    apk del openssl
COPY nginx-httpbin.conf /etc/nginx/conf.d/default.conf
